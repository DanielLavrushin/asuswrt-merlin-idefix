[
  { "label": "Live syslog", "cmd": "tail -f /tmp/syslog.log", "category": "Logs" },
  { "label": "Last 50 log lines", "cmd": "tail -50 /tmp/syslog.log", "category": "Logs" },
  { "label": "Kernel log", "cmd": "dmesg | tail -50", "category": "Logs" },
  { "label": "Wireless log", "cmd": "grep -i 'wl\\|wireless\\|802\\.11' /tmp/syslog.log | tail -30", "category": "Logs" },
  { "label": "DHCP log", "cmd": "grep -i 'dnsmasq\\|dhcp' /tmp/syslog.log | tail -30", "category": "Logs" },
  { "label": "VPN log", "cmd": "grep -i 'vpn\\|openvpn\\|wireguard' /tmp/syslog.log | tail -30", "category": "Logs" },

  { "label": "Process monitor", "cmd": "top", "category": "System" },
  { "label": "Memory usage", "cmd": "free", "category": "System" },
  { "label": "Uptime & load", "cmd": "uptime", "category": "System" },
  { "label": "Disk usage", "cmd": "df -h", "category": "System" },
  { "label": "CPU info", "cmd": "cat /proc/cpuinfo", "category": "System" },
  { "label": "Running processes", "cmd": "ps w", "category": "System" },
  { "label": "Mounted filesystems", "cmd": "mount", "category": "System" },
  { "label": "USB devices", "cmd": "lsusb", "category": "System" },
  { "label": "USB storage", "cmd": "ls -la /tmp/mnt/", "category": "System" },
  { "label": "JFFS usage", "cmd": "df -h /jffs && echo '---' && du -sh /jffs/*/ 2>/dev/null", "category": "System" },
  { "label": "Temperature (CPU)", "cmd": "cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null && echo '(millidegrees C)' || echo 'N/A'", "category": "System" },
  { "label": "Temperature (WiFi)", "cmd": "for iface in eth6 eth7 wl0 wl1; do t=$(wl -i $iface phy_tempsense 2>/dev/null) && echo \"$iface: $t\" ; done", "category": "System" },
  { "label": "Firmware version", "cmd": "nvram get buildno && nvram get extendno", "category": "System" },
  { "label": "Model info", "cmd": "nvram get model && nvram get productid", "category": "System" },
  { "label": "Reboot router", "cmd": "echo 'Type: reboot' ", "category": "System" },

  { "label": "IP routes", "cmd": "ip route", "category": "Network" },
  { "label": "Network interfaces", "cmd": "ifconfig", "category": "Network" },
  { "label": "Active connections", "cmd": "netstat -tlnp", "category": "Network" },
  { "label": "ARP table", "cmd": "arp -a", "category": "Network" },
  { "label": "DNS resolv.conf", "cmd": "cat /tmp/resolv.conf", "category": "Network" },
  { "label": "Connected clients (DHCP)", "cmd": "cat /var/lib/misc/dnsmasq.leases", "category": "Network" },
  { "label": "Ping google.com", "cmd": "ping -c 4 google.com", "category": "Network" },
  { "label": "DNS lookup test", "cmd": "nslookup google.com", "category": "Network" },
  { "label": "WAN IP (internal)", "cmd": "nvram get wan0_ipaddr", "category": "Network" },
  { "label": "WAN gateway", "cmd": "nvram get wan0_gateway", "category": "Network" },
  { "label": "WAN DNS servers", "cmd": "nvram get wan0_dns", "category": "Network" },
  { "label": "LAN settings", "cmd": "echo \"IP: $(nvram get lan_ipaddr)\" && echo \"Mask: $(nvram get lan_netmask)\" && echo \"Domain: $(nvram get lan_domain)\"", "category": "Network" },
  { "label": "Connection tracking count", "cmd": "echo \"$(cat /proc/sys/net/netfilter/nf_conntrack_count) / $(cat /proc/sys/net/netfilter/nf_conntrack_max)\"", "category": "Network" },
  { "label": "Top connections by IP", "cmd": "cat /proc/net/nf_conntrack | awk '{for(i=1;i<=NF;i++) if($i~/^src=/) print $i}' | sort | uniq -c | sort -rn | head -15", "category": "Network" },
  { "label": "Bandwidth (live)", "cmd": "watch -n1 'cat /proc/net/dev | grep -E \"eth|br|vlan\"'", "category": "Network" },

  { "label": "WiFi clients (all bands)", "cmd": "for iface in eth1 eth2 eth3 eth4 eth5 eth6 eth7 wl0 wl1 wl0.1 wl1.1; do list=$(wl -i $iface assoclist 2>/dev/null) && [ -n \"$list\" ] && echo \"=== $iface ===\" && echo \"$list\"; done", "category": "WiFi" },
  { "label": "WiFi interface status", "cmd": "for iface in eth1 eth2 eth3 eth4 eth5 eth6 eth7 wl0 wl1; do s=$(wl -i $iface status 2>/dev/null) && [ -n \"$s\" ] && echo \"=== $iface ===\" && echo \"$s\" | head -5 && echo; done", "category": "WiFi" },
  { "label": "WiFi interfaces list", "cmd": "nvram show 2>/dev/null | grep -E '^wl[0-9]_ifname='", "category": "WiFi" },

  { "label": "Firewall rules (filter)", "cmd": "iptables -L -n --line-numbers | head -80", "category": "Firewall" },
  { "label": "NAT rules", "cmd": "iptables -t nat -L -n --line-numbers | head -80", "category": "Firewall" },
  { "label": "Port forwarding", "cmd": "iptables -t nat -L VSERVER -n --line-numbers 2>/dev/null || echo 'No VSERVER chain'", "category": "Firewall" },
  { "label": "Blocked recent (DROP log)", "cmd": "grep -i 'drop' /tmp/syslog.log | tail -20", "category": "Firewall" },

  { "label": "VPN client status", "cmd": "for i in 1 2 3 4 5; do s=$(nvram get vpn_client${i}_state 2>/dev/null); [ -n \"$s\" ] && echo \"Client $i: state=$s\"; done", "category": "VPN" },
  { "label": "VPN server status", "cmd": "for i in 1 2; do s=$(nvram get vpn_server${i}_state 2>/dev/null); [ -n \"$s\" ] && echo \"Server $i: state=$s\"; done", "category": "VPN" },
  { "label": "WireGuard interfaces", "cmd": "wg show 2>/dev/null || echo 'WireGuard not active'", "category": "VPN" },
  { "label": "OpenVPN processes", "cmd": "ps w | grep -v grep | grep openvpn", "category": "VPN" },

  { "label": "NVRAM search", "cmd": "nvram show 2>/dev/null | grep -i \"\"", "category": "NVRAM" },
  { "label": "NVRAM show all", "cmd": "nvram show 2>/dev/null | head -100", "category": "NVRAM" },
  { "label": "NVRAM usage", "cmd": "nvram show 2>/dev/null | wc -c && echo '/ 65536 bytes'", "category": "NVRAM" },

  { "label": "Entware packages", "cmd": "opkg list-installed", "category": "Entware" },
  { "label": "Entware update", "cmd": "opkg update", "category": "Entware" },
  { "label": "Entware disk usage", "cmd": "du -sh /opt/ 2>/dev/null && echo '---' && du -sk /opt/*/ 2>/dev/null | sort -rn | head -10", "category": "Entware" },

  { "label": "Crontab list", "cmd": "cru l", "category": "Scheduled Tasks" },
  { "label": "User scripts list", "cmd": "ls -la /jffs/scripts/", "category": "Scheduled Tasks" },
  { "label": "Addons list", "cmd": "ls -la /jffs/addons/", "category": "Scheduled Tasks" },
  { "label": "Running services", "cmd": "service show_status 2>/dev/null || ps w | grep -v grep | grep -E 'dnsmasq|httpd|miniupnp|avahi|samba|nmbd|vsftpd'", "category": "Scheduled Tasks" }
]
